# ===========================================
# gmail-im-notify — 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入真实值
# 注意：Google Apps Script 中配置在 CONFIG 对象内
# 此文件仅作为文档参考
# ===========================================

# DeepSeek API 密钥
# 注册: https://platform.deepseek.com
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-v4-flash

# 钉钉机器人 Webhook URL
# 创建: 钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK=YOUR_DINGTALK_WEBHOOK_URL

# 钉钉加签密钥 (SEC 开头)
DINGTALK_SECRET=YOUR_DINGTALK_SECRET

# 检查频率（分钟）
CHECK_MINUTES=1

# 每次最多处理邮件数
MAX_PER_BATCH=5
